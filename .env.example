# ============================================================
# EXAMPLE (copy this file to .env and replace values below)
# ============================================================
#
# GMAIL_SENDER=myaccount@gmail.com
# GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
# GMAIL_RECIPIENT=alerts@gmail.com
#
# SLACK_BOT_TOKEN=xoxb-<your-bot-token-here>
# SLACK_CHANNEL=#docs-updates
#
# ALERT_MODE=per-site
#
# WATCH_URLS=https://geminicli.com/docs/,https://docs.tabnine.com,https://docs.github.com/en/copilot
#
# ============================================================

# Gmail credentials (SMTP + App Password, SSL port 465)
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_RECIPIENT=you@gmail.com

# Slack Bot Token (xoxb-...) with chat:write scope
SLACK_BOT_TOKEN=xoxb-<your-bot-token-here>
SLACK_CHANNEL=#your-channel

# Alert mode: 'per-site' (one message per changed site) or 'digest' (one combined message)
# Can be overridden by CLI flag: python3 watcher.py --mode digest
# Can also be set at runtime via Slack slash command (stored in config.json).
ALERT_MODE=per-site

# Comma-separated list of docs base URLs to monitor.
# All sub-pages linked from each URL are crawled automatically.
WATCH_URLS=https://geminicli.com/docs/,https://docs.tabnine.com,https://docs.github.com/en/copilot,https://cursor.com/docs,https://gitbook.com/docs,https://docs.slack.dev/,https://code.claude.com/docs/en/overview,https://developers.openai.com/codex
